{
  "name": "@open-adventure/core",
  "version": "1.0.0",
  "description": "Open Adventure game engine — platform-agnostic core",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtritchie/open-adventure-ts.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/gtritchie/open-adventure-ts#readme",
  "bugs": {
    "url": "https://github.com/gtritchie/open-adventure-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/make-dungeon.ts",
    "generate:check": "tsx scripts/make-dungeon.ts --check",
    "test": "vitest run"
  },
  "license": "BSD-2-Clause"
}
